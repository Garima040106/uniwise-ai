# Django
DEBUG=False
SECRET_KEY=change-this-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost

# Cookie / SSL flags
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Database
DB_PORT=5432
POSTGRES_DB=uniwise_db
POSTGRES_USER=uniwise_user
POSTGRES_PASSWORD=uniwise_pass

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_REQUEST_TIMEOUT=180
OLLAMA_MAX_RETRIES=1
OLLAMA_NUM_PREDICT=700
AI_CONTEXT_CHAR_LIMIT=2200

# AI / uploads
MAX_UPLOAD_SIZE=10485760
RAG_MAX_DISTANCE=1.2
RAG_ANSWER_CACHE_TIMEOUT=300
CACHE_BACKEND=locmem
# REDIS_CACHE_URL=redis://redis:6379/1
# UNIVERSITY_DB_ALIAS_MAP=1:uni_1,2:uni_2
API_THROTTLE_ANON=60/min
API_THROTTLE_USER=300/min

# Frontend build/runtime
REACT_APP_API_BASE_URL=/api
WEB_PORT=80
